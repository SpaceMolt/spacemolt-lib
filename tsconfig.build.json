{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src"
    // Source uses .ts import specifiers; scripts/fix-dts-extensions.ts rewrites
    // them to .js in the emitted declarations after this runs.
  },
  "include": ["src"],
  "exclude": ["scripts", "tests"]
}
